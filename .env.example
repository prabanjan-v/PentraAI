# ─────────────────────────────────────────────────────────────────
# PentraAI — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to GitHub — it contains secret keys.
# ─────────────────────────────────────────────────────────────────

# ── Choose your LLM provider ─────────────────────────────────────
# Change this ONE value to switch between providers:
#   groq    → free, fast          (recommended for development)
#   gemini  → free tier, Google   (good backup)
#   claude  → paid, most accurate (best for final demo)
LLM_PROVIDER=groq

# ── Groq API — FREE ───────────────────────────────────────────────
# Get your key at: console.groq.com (no credit card needed)
GROQ_API_KEY=gsk_your_key_here
# Options: llama-3.1-70b-versatile | llama-3.1-8b-instant | mixtral-8x7b-32768
GROQ_MODEL=llama-3.1-70b-versatile

# ── Gemini API — FREE TIER ────────────────────────────────────────
# Get your key at: aistudio.google.com → Get API Key (no credit card)
GEMINI_API_KEY=AIza_your_key_here
# Options: gemini-1.5-flash | gemini-1.5-pro
GEMINI_MODEL=gemini-1.5-flash

# ── Claude API — PAID ─────────────────────────────────────────────
# Get your key at: console.anthropic.com (separate from Claude Pro)
# Cost: ~$0.001 per call with Haiku — full project costs under $5
CLAUDE_API_KEY=sk-ant-your_key_here
# Options: claude-haiku-4-5-20251001 | claude-sonnet-4-6
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ── App settings ─────────────────────────────────────────────────
DEBUG=false
MAX_ENDPOINTS=50
REQUEST_TIMEOUT=10
MAX_CONCURRENT=5
